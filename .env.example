# ============================================================
# SQL Server MCP - Configuración de conexión
# Copia este archivo como .env y ajusta los valores
# ============================================================

# --- Conexión principal ---
MSSQL_SERVER=localhost          # IP o nombre del servidor
MSSQL_PORT=1433                 # Puerto (default 1433)
MSSQL_DATABASE=mi_base          # Base de datos por defecto
MSSQL_USERNAME=sa               # Usuario SQL
MSSQL_PASSWORD=TuPassword123!   # Contraseña
MSSQL_DRIVER=ODBC Driver 17 for SQL Server   # Driver ODBC instalado

# --- Opciones de conexión ---
MSSQL_ENCRYPT=yes               # Encriptar conexión (yes/no)
MSSQL_TRUST_CERT=no             # Confiar en cert autofirmado (dev: yes)
MSSQL_TIMEOUT=30                # Timeout de conexión en segundos
MSSQL_QUERY_TIMEOUT=0           # Timeout de queries en segundos (0=sin límite)
MSSQL_POOL_SIZE=5               # Tamaño del pool de conexiones
MSSQL_CHAR_ENCODING=cp1252      # Encoding de lectura de VARCHAR: cp1252, latin-1, utf-8
MSSQL_WRITE_ENCODING=cp1252     # Encoding de escritura: cp1252 para VARCHAR, utf-8 para NVARCHAR

# --- Seguridad del MCP ---
# Lista de operaciones habilitadas (separadas por coma)
# Opciones: select, insert, update, delete, ddl, exec_sp, ddl_sp
MSSQL_ALLOWED_OPS=select,insert,update,delete,exec_sp,ddl,ddl_sp

# Schemas permitidos (vacío = todos)
MSSQL_ALLOWED_SCHEMAS=dbo,translations

# Prefijo de tablas permitidas para DDL (vacío = todas)
# Ejemplo: "tbl_,cat_" solo permite CREATE en tablas con ese prefijo
MSSQL_DDL_TABLE_PREFIX=

# --- Logging ---
MSSQL_LOG_QUERIES=true          # Loggear todas las queries ejecutadas
MSSQL_LOG_PARAMS=true           # Incluir valores de parámetros en logs
MSSQL_LOG_LEVEL=INFO            # DEBUG | INFO | WARNING | ERROR
